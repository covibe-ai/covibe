# Covibe 环境变量模板
# 复制为 .env 并填入实际值

# ─── 必需 ───
HANDY_MASTER_SECRET=change-me-to-a-random-64-char-string
DJANGO_SECRET_KEY=change-me-to-a-random-64-char-string
ROOT_PASSWORD=rootroot

# ─── 数据库 ───
DB_PASSWORD=covibe

# ─── 域名 ───
DJANGO_ALLOWED_HOSTS=localhost,api.covibe.ai
CORS_ALLOWED_ORIGINS=https://covibe.ai,https://dashboard.covibe.ai
SUPERUSER_EMAIL=root@covibe.ai
